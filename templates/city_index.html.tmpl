<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sun Forecast Cities | iwannasun</title>
  <meta name="description" content="Browse city sun forecast pages and open the live iwannasun timeline for your location." />
  <link rel="canonical" href="https://iwannasun.com/sun/" />
  <meta property="og:title" content="Sun Forecast Cities | iwannasun" />
  <meta property="og:description" content="Browse city pages and check when sunlight is most likely to break through." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://iwannasun.com/sun/" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Sun Forecast Cities | iwannasun" />
  <meta name="twitter:description" content="Open city pages to check likely sun windows with iwannasun." />
  <link rel="stylesheet" href="/styles.css">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="manifest" href="/site.webmanifest">
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/" aria-label="iwannasun home">
      <img class="brandLogo" src="/iwannasunlogowtext.svg" alt="iwannasun" />
      <div class="brandText">
        <h1 class="sub">City sun forecast pages</h1>
      </div>
    </a>
  </header>

  <main class="wrap">
    <section class="card notes" aria-labelledby="cityIndexHeading">
      <h2 class="muted small sectionHeading" id="cityIndexHeading">Available cities</h2>
      <div class="muted small aboutText">
        <p>Select a city to open its sun forecast page.</p>
        <ul class="cityList">
${city_links}
        </ul>
      </div>
    </section>
  </main>

  <footer class="wrap siteFooter">
    <p class="muted small">iwannasun is a weather-based sunlight planning tool for daily outdoor decisions.</p>
  </footer>
</body>
</html>
